---
import { site } from "@/data/site";

const year = new Date().getFullYear();

const columns = [
  {
    title: "Empresa",
    links: [
      ["Nosotros", "/nosotros/"],
      ["Servicios", "/servicios/"],
      ["Casos", "/casos/"],
      ["Blog", "/blog/"],
      ["Contacto", "/contacto/"],
    ],
  },
  {
    title: "Servicios",
    links: [
      ["Desarrollo Web", "/servicios/"],
      ["SEO Avanzado", "/servicios/"],
      ["Paid Media", "/servicios/"],
      ["Branding", "/servicios/"],
      ["Automatización e IA", "/servicios/"],
      ["CRM y Analítica", "/servicios/"],
    ],
  },
  {
    title: "Recursos",
    links: [
      ["Diagnóstico gratuito", "/#diagnostico"],
      ["Insights", "/blog/"],
      ["Preguntas frecuentes", "/#diagnostico-interactivo"],
      ["Política de privacidad", "/politicas/"],
    ],
  },
];

const contact = [
  ["Email", site.email, `mailto:${site.email}`],
  ["WhatsApp", "+56 9 XXXX XXXX", "/contacto/"],
  ["Ubicación", "Chile", "/contacto/"],
];
---

<footer class="relative overflow-hidden bg-enix-ink text-white">
  <div class="pointer-events-none absolute left-1/2 top-0 h-96 w-[42rem] -translate-x-1/2 rounded-full bg-enix-red/12 blur-3xl"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-enix-red/70 to-transparent"></div>

  <div class="container relative py-16 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.15fr_1.55fr_0.75fr]">
      <section class="max-w-md">
        <a class="inline-flex" href="/" aria-label="ENIX STUDIO inicio">
          <img
            class="h-10 w-auto object-contain brightness-0 invert md:h-12"
            src="/brand/enix-logo.png"
            alt="ENIX Studio"
            width="1578"
            height="447"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="mt-6 text-sm font-semibold leading-7 text-slate-400">
          Agencia digital de NOVVOR especializada en estrategia, diseño, tecnología, automatización y crecimiento digital.
        </p>
        <a class="btn btn-primary mt-7" href="/#diagnostico">Solicitar diagnóstico gratuito</a>
      </section>

      <nav class="grid gap-8 sm:grid-cols-3" aria-label="Navegación del footer">
        {columns.map((column) => (
          <div>
            <h2 class="text-sm font-black uppercase tracking-[0.12em] text-white">{column.title}</h2>
            <ul class="mt-5 grid gap-3">
              {column.links.map(([label, href]) => (
                <li>
                  <a class="group inline-flex items-center gap-2 text-sm font-semibold text-slate-400 transition hover:text-white" href={href}>
                    <span class="h-px w-0 bg-enix-red transition-all group-hover:w-4"></span>
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <section>
        <h2 class="text-sm font-black uppercase tracking-[0.12em] text-white">Contacto</h2>
        <ul class="mt-5 grid gap-4">
          {contact.map(([label, value, href]) => (
            <li class="rounded-2xl border border-white/[0.07] bg-white/[0.035] p-4">
              <span class="block text-xs font-black uppercase tracking-[0.1em] text-enix-glow">{label}</span>
              <a class="mt-1 block text-sm font-bold text-slate-300 transition hover:text-white" href={href}>{value}</a>
            </li>
          ))}
        </ul>
        <div class="mt-5 flex gap-3" aria-label="Redes sociales">
          {["in", "ig", "x"].map((item) => (
            <a class="grid size-10 place-items-center rounded-full border border-white/[0.08] bg-white/[0.04] text-xs font-black text-slate-300 transition hover:border-enix-red/40 hover:bg-enix-red/10 hover:text-white" href="/contacto/" aria-label={`Red social ${item.toUpperCase()}`}>
              {item.toUpperCase()}
            </a>
          ))}
        </div>
      </section>
    </div>

    <div class="mt-14 flex flex-col gap-4 border-t border-white/[0.08] pt-6 text-xs font-semibold text-slate-500 md:flex-row md:items-center md:justify-between">
      <p>© {year} Enix Studio. Agencia digital de NOVVOR. Todos los derechos reservados.</p>
      <div class="flex flex-wrap gap-4">
        <a class="transition hover:text-white" href="/politicas/">Política de privacidad</a>
        <a class="transition hover:text-white" href="/politicas/">Términos y condiciones</a>
      </div>
    </div>
  </div>
</footer>
