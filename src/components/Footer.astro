---
import Icon from "@/components/Icon.astro";
import { site } from "@/data/site";

const year = Math.max(new Date().getFullYear(), 2026);

const services = [
  ["Desarrollo Web y Plataformas Digitales", "/servicios/desarrollo-web/"],
  ["SEO Avanzado", "/servicios/seo/"],
  ["Paid Media", "/servicios/paid-media/"],
  ["Automatizacion e IA", "/servicios/automatizacion-ia/"],
  ["Branding y Comunicacion", "/servicios/branding/"],
  ["Analitica y Tracking", "/servicios/analitica-tracking/"],
];

const solutions = [
  ["Mejorar mi web", "/diagnostico?problema=conversion"],
  ["Aparecer en Google", "/diagnostico?problema=seo"],
  ["Medir campanas", "/diagnostico?problema=tracking"],
  ["Automatizar seguimiento", "/diagnostico?problema=automatizacion"],
  ["Mejorar mi marca", "/diagnostico?problema=branding"],
  ["No se por donde empezar", "/diagnostico?problema=estrategia"],
];

const markets = [
  ["Chile", "/cl/"],
  ["Region Metropolitana", "/cl/region-metropolitana/"],
  ["Region de Antofagasta", "/cl/region-antofagasta/"],
  ["Empresas B2B", "/industrias/empresas-b2b/"],
  ["Empresas industriales", "/industrias/empresas-industriales/"],
];

const industries = [
  ["Empresas B2B", "/industrias/empresas-b2b/"],
  ["Empresas industriales", "/industrias/empresas-industriales/"],
  ["Proveedores mineros", "/industrias/proveedores-mineros/"],
  ["Servicios profesionales", "/industrias/servicios-profesionales/"],
  ["Ecommerce", "/industrias/ecommerce/"],
];

const resources = [
  ["Blog", "/blog/"],
  ["Casos y soluciones", "/casos/"],
  ["Nosotros", "/nosotros/"],
  ["Contacto", "/contacto/"],
  ["Diagnostico gratuito", "/diagnostico/"],
];

const legal = [
  ["Politica de Privacidad", "/politica-de-privacidad/"],
  ["Contacto corporativo", "/contacto/"],
];

const groups = [
  ["Servicios", services],
  ["Soluciones", solutions],
  ["Mercados", markets],
  ["Industrias", industries],
  ["Recursos", resources],
  ["Legal", legal],
] as const;
---

<footer class="relative overflow-hidden bg-[#070b14] text-white">
  <div class="absolute inset-0">
    <div class="absolute left-[-10%] top-[-20%] h-[420px] w-[420px] rounded-full bg-red-600/12 blur-[120px]"></div>
    <div class="absolute bottom-[-20%] right-[-10%] h-[420px] w-[420px] rounded-full bg-blue-500/12 blur-[120px]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.035)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.035)_1px,transparent_1px)] bg-[size:72px_72px] opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#070b14] via-[#070b14]/90 to-black"></div>
  </div>

  <div class="container relative">
    <div class="grid gap-10 py-14 lg:grid-cols-[1.15fr_2fr]">
      <section>
        <a class="inline-flex" href="/" aria-label="ENIX STUDIO inicio">
          <img
            class="h-10 w-auto object-contain brightness-0 invert md:h-12"
            src="/brand/enix-logo.png"
            alt="ENIX Studio"
            width="1578"
            height="447"
            loading="lazy"
            decoding="async"
          />
        </a>

        <p class="mt-6 max-w-md text-sm leading-7 text-slate-300">
          Enix Studio es la agencia digital de NOVVOR. Creamos sistemas de crecimiento digital que conectan estrategia, desarrollo web, SEO, campanas, automatizacion, IA y analitica para empresas B2B, industriales y de servicios.
        </p>

        <div class="mt-6 space-y-3">
          <a class="group flex items-center gap-3 text-sm font-bold text-slate-300 transition hover:text-white" href={`mailto:${site.email}`}>
            <span class="flex size-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-red-300 transition group-hover:border-red-300/60 group-hover:bg-red-500/10">
              <Icon name="mail" class="size-4" />
            </span>
            {site.email}
          </a>

          <div class="flex items-center gap-3 text-sm font-bold text-slate-300">
            <span class="flex size-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-red-300">
              <Icon name="map" class="size-4" />
            </span>
            Chile - Atencion remota para empresas
          </div>
        </div>

        <div class="mt-6">
          <a
            class="inline-flex size-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-sm font-black text-slate-300 transition hover:-translate-y-1 hover:border-red-300/70 hover:bg-red-500/10 hover:text-white"
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn de Enix Studio"
          >
            in
          </a>
        </div>
      </section>

      <nav class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3" aria-label="Navegacion del footer">
        {groups.map(([title, links]) => (
          <section>
            <p class="text-sm font-black uppercase tracking-[0.2em] text-white">{title}</p>
            <ul class="mt-5 grid gap-3">
              {links.map(([label, href]) => (
                <li>
                  <a
                    class="group inline-flex min-h-11 items-center text-sm leading-6 text-slate-400 transition hover:text-white"
                    href={href}
                    rel={href.includes("?") ? "nofollow" : undefined}
                  >
                    <span class="transition group-hover:translate-x-1">{label}</span>
                    <Icon name="chevronRight" class="ml-2 size-3.5 opacity-0 transition group-hover:translate-x-1 group-hover:opacity-100" />
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </nav>
    </div>

    <div class="border-t border-white/10 py-6">
      <div class="flex flex-col gap-4 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
        <p>© {year} Enix Studio. Agencia digital de NOVVOR. Todos los derechos reservados.</p>

        <div class="flex flex-wrap gap-4">
          <a class="transition hover:text-white" href="/politica-de-privacidad/">Politica de Privacidad</a>
          <a class="transition hover:text-white" href={`mailto:${site.email}`}>{site.email}</a>
          <a class="transition hover:text-white" href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </div>
</footer>
