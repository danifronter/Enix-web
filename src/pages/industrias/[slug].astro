---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import { industryPages, type IndustryPage } from "@/data/industryPagesData";
import { site } from "@/data/site";

export const prerender = true;

export function getStaticPaths() {
  return industryPages.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props as { industry: IndustryPage };
const canonical = `${site.url}/industrias/${industry.slug}/`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: industry.title,
  description: industry.metaDescription,
  provider: { "@type": "Organization", name: site.name, url: site.url },
  areaServed: "Chile",
  url: canonical,
};
---

<BaseLayout
  title={industry.seoTitle}
  description={industry.metaDescription}
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Industrias", url: `${site.url}/industrias/` }, { name: industry.title, url: canonical }]}
  extraSchemas={[serviceSchema]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <main>
    <section class="relative overflow-hidden bg-enix-ink py-24 text-white lg:py-28">
      <div class="container relative">
        <p class="eyebrow">Industria</p>
        <h1 class="mt-4 max-w-5xl text-5xl font-black leading-tight md:text-7xl">{industry.h1}</h1>
        <p class="mt-6 max-w-3xl text-lg font-semibold leading-8 text-slate-300">{industry.intro}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="btn btn-primary" href={`/diagnostico?industria=${industry.slug}`} rel="nofollow">Solicitar diagnostico</a>
          <a class="btn btn-secondary" href="/servicios/">Explorar servicios digitales</a>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Desafios</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Problemas comunes que conviene resolver con estrategia.</h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {industry.challenges.map((challenge) => (
            <article class="rounded-xl border border-slate-200 bg-slate-50 p-5">
              <Icon name="alert" class="size-5 text-enix-red" />
              <p class="mt-4 font-bold leading-7 text-slate-700">{challenge}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container grid gap-10 lg:grid-cols-2">
        <div>
          <p class="eyebrow">Servicios recomendados</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {industry.services.map((service) => (
              <span class="rounded-full bg-white px-4 py-2 text-sm font-black text-slate-700 shadow-sm">{service}</span>
            ))}
          </div>
        </div>
        <div>
          <p class="eyebrow">Resultados buscados</p>
          <div class="mt-6 grid gap-3">
            {industry.outcomes.map((outcome) => (
              <div class="flex items-center gap-3 rounded-xl bg-white p-4 font-black text-slate-900 shadow-sm">
                <Icon name="check" class="size-5 text-enix-red" />
                {outcome}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
