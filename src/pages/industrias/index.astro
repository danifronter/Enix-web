---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import { industryPages } from "@/data/industryPagesData";
import { site } from "@/data/site";

export const prerender = true;

const title = "Industrias B2B e Industriales | Enix Studio";
const description =
  "Soluciones digitales para empresas B2B, industriales y proveedores mineros que necesitan presencia profesional, captacion y medicion.";
const canonical = `${site.url}/industrias/`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Industrias", url: canonical }]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <main>
    <section class="relative overflow-hidden bg-enix-ink py-24 text-white lg:py-28">
      <div class="container">
        <p class="eyebrow">Industrias</p>
        <h1 class="mt-4 max-w-5xl text-[clamp(2.1rem,3.5vw,3.55rem)] font-black leading-[1.03] tracking-tight">Soluciones digitales para mercados donde la confianza pesa.</h1>
        <p class="mt-6 max-w-3xl text-lg font-semibold leading-8 text-slate-300">
          Enix Studio trabaja con empresas B2B, industriales y proveedores especializados que necesitan comunicar mejor, captar oportunidades y medir lo que ocurre.
        </p>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-5 md:grid-cols-3">
        {industryPages.map((industry) => (
          <a class="group rounded-xl border border-slate-200 bg-slate-50 p-6 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white hover:shadow-premium" href={`/industrias/${industry.slug}/`}>
            <span class="icon-box mb-5"><Icon name="briefcase" class="size-5" /></span>
            <h2 class="text-2xl font-black group-hover:text-enix-red">{industry.title}</h2>
            <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">{industry.metaDescription}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
