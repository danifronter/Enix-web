---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import AnimatedHeroBackground from "@/components/hero/AnimatedHeroBackground";
import { blogArticles, categorySlug, type BlogArticle } from "@/data/blogData";
import { site } from "@/data/site";

export function getStaticPaths() {
  return blogArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const canonical = `${site.url}/blog/${article.slug}/`;
const related = article.related
  .map((slug) => blogArticles.find((item) => item.slug === slug))
  .filter((item): item is BlogArticle => Boolean(item));
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.description,
  image: `${site.url}${article.coverImage}`,
  datePublished: article.publishedAt,
  dateModified: article.updatedAt,
  author: { "@type": "Organization", name: article.author },
  publisher: { "@type": "Organization", name: site.name },
  mainEntityOfPage: canonical,
  keywords: article.keywords.join(", "),
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: article.faq.map(([question, answer]) => ({
    "@type": "Question",
    name: question,
    acceptedAnswer: { "@type": "Answer", text: answer },
  })),
};
---

<BaseLayout
  title={`${article.title} | ENIX STUDIO`}
  description={article.description}
  canonical={canonical}
  ogImage={`${site.url}${article.coverImage}`}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Blog", url: `${site.url}/blog/` }, { name: article.title, url: canonical }]}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:load />
  <main>
    <div class="fixed inset-x-0 top-0 z-[45] h-1 bg-transparent">
      <div class="h-full w-1/3 bg-gradient-to-r from-enix-red to-enix-glow"></div>
    </div>
    <article>
      <header class="motion-reduce-safe relative isolate overflow-hidden bg-[#070b14] pb-20 pt-36 text-white md:pt-44">
        <AnimatedHeroBackground client:load variant="blog" intensity="soft" />
        <div class="container relative z-10 max-w-5xl">
          <a class="eyebrow" href={`/blog/categoria/${categorySlug(article.category)}/`}>{article.category}</a>
          <h1 class="mt-5 text-5xl font-black leading-[0.98] md:text-7xl">{article.title}</h1>
          <p class="mt-7 max-w-3xl text-xl leading-9 text-slate-300">{article.description}</p>
          <div class="mt-8 flex flex-wrap gap-3 text-sm font-bold text-slate-400">
            <span>{article.author}</span><span>·</span><time datetime={article.publishedAt}>{article.publishedAt}</time><span>·</span><span>Actualizado {article.updatedAt}</span><span>·</span><span>{article.readingTime}</span>
          </div>
        </div>
      </header>

      <section class="bg-white py-14">
        <div class="container grid gap-10 lg:grid-cols-[0.28fr_0.72fr]">
          <aside class="lg:sticky lg:top-28 lg:self-start">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
              <h2 class="font-black">Tabla de contenidos</h2>
              <ol class="mt-4 grid gap-2 text-sm font-semibold text-slate-600">
                {article.sections.map((section) => (
                  <li><a class="hover:text-enix-red" href={`#${section.heading.toLowerCase().replaceAll(" ", "-").replaceAll(":", "")}`}>{section.heading}</a></li>
                ))}
              </ol>
            </div>
          </aside>

          <div class="max-w-3xl">
            <p class="text-2xl font-semibold leading-10 text-slate-800">{article.intro}</p>
            {article.sections.map((section, index) => (
              <section id={section.heading.toLowerCase().replaceAll(" ", "-").replaceAll(":", "")} class="scroll-mt-28">
                <h2 class="mt-12 text-3xl font-black leading-tight text-slate-950 md:text-4xl">{section.heading}</h2>
                {section.body.map((paragraph) => <p class="mt-5 leading-8 text-slate-700">{paragraph}</p>)}
                {section.bullets && (
                  <ul class="mt-5 grid gap-3">
                    {section.bullets.map((bullet) => <li class="flex gap-3 rounded-xl bg-slate-50 p-4 font-semibold text-slate-700"><Icon name="check" class="mt-1 size-4 shrink-0 text-enix-red" /> {bullet}</li>)}
                  </ul>
                )}
                {index === 3 && (
                  <div class="mt-10 rounded-3xl bg-enix-ink p-6 text-white">
                    <p class="eyebrow">CTA contextual</p>
                    <h3 class="mt-3 text-2xl font-black">{article.primaryCta}</h3>
                    <p class="mt-3 leading-7 text-slate-300">Revisemos este problema aplicado a tu empresa y prioricemos oportunidades concretas.</p>
                    <a class="btn btn-primary mt-5" href="/#diagnostico">Solicitar diagnóstico gratuito</a>
                  </div>
                )}
              </section>
            ))}

            <section class="mt-14 rounded-3xl border border-slate-200 bg-slate-50 p-6">
              <h2 class="text-3xl font-black">Ejemplos prácticos</h2>
              <ul class="mt-5 grid gap-3">
                {article.examples.map((example) => <li class="flex gap-3 leading-7 text-slate-700"><Icon name="target" class="mt-1 size-5 shrink-0 text-enix-red" /> {example}</li>)}
              </ul>
            </section>

            <section class="mt-10">
              <h2 class="text-3xl font-black">Errores comunes</h2>
              <div class="mt-5 grid gap-3 md:grid-cols-2">
                {article.commonMistakes.map((mistake) => <div class="rounded-2xl border border-slate-200 p-4 font-bold text-slate-700">{mistake}</div>)}
              </div>
            </section>

            <section class="mt-10 rounded-3xl bg-enix-ink p-7 text-white">
              <p class="eyebrow">Servicio recomendado</p>
              <h2 class="mt-3 text-3xl font-black">{article.serviceRelated}</h2>
              <p class="mt-4 leading-8 text-slate-300">{article.recommendedSolution}</p>
              <div class="mt-6 flex flex-wrap gap-3">
                <a class="btn btn-primary" href="/#diagnostico">{article.finalCta}</a>
                <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
              </div>
            </section>

            <section class="mt-12">
              <h2 class="text-3xl font-black">Preguntas frecuentes</h2>
              <div class="mt-5 grid gap-3">
                {article.faq.map(([question, answer]) => (
                  <details class="rounded-2xl border border-slate-200 bg-white p-5">
                    <summary class="cursor-pointer font-black">{question}</summary>
                    <p class="mt-3 leading-7 text-slate-600">{answer}</p>
                  </details>
                ))}
              </div>
            </section>

            <section class="mt-12">
              <h2 class="text-3xl font-black">Artículos relacionados</h2>
              <div class="mt-5 grid gap-4 md:grid-cols-3">
                {related.map((item) => (
                  <a class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white" href={`/blog/${item.slug}/`}>
                    <span class="eyebrow">{item.category}</span>
                    <h3 class="mt-2 font-black leading-snug">{item.title}</h3>
                  </a>
                ))}
              </div>
            </section>
          </div>
        </div>
      </section>
    </article>
  </main>
  <Footer />
</BaseLayout>
