---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import AnimatedHeroBackground from "@/components/hero/AnimatedHeroBackground";
import { blogCategories, categorySlug, getArticlesByCategory } from "@/data/blogData";
import { site } from "@/data/site";

export function getStaticPaths() {
  return blogCategories.map((category) => ({
    params: { category: categorySlug(category) },
    props: { category, articles: getArticlesByCategory(categorySlug(category)) },
  }));
}

const { category, articles } = Astro.props;
const canonical = `${site.url}/blog/categoria/${categorySlug(category)}/`;
---

<BaseLayout
  title={`${category} para empresas | Blog ENIX STUDIO`}
  description={`Guías de ${category} para empresas que quieren mejorar posicionamiento, conversión, automatización y crecimiento digital.`}
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Blog", url: `${site.url}/blog/` }, { name: category, url: canonical }]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:load />
  <main>
    <section class="motion-reduce-safe relative isolate overflow-hidden bg-[#070b14] pb-20 pt-36 text-white md:pt-44">
      <AnimatedHeroBackground client:load variant="blog" intensity="soft" />
      <div class="container relative z-10">
        <p class="eyebrow">Categoría</p>
        <h1 class="mt-4 max-w-4xl text-5xl font-black md:text-7xl">{category}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">Artículos estratégicos para tomar mejores decisiones y convertir conocimiento en oportunidades comerciales.</p>
      </div>
    </section>
    <section class="section bg-enix-pearl">
      <div class="container">
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {articles.map((article) => (
            <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-enix-red/30 hover:shadow-premium">
              <p class="eyebrow">{article.category}</p>
              <h2 class="mt-3 text-2xl font-black leading-tight group-hover:text-enix-red">
                <a href={`/blog/${article.slug}/`}>{article.title}</a>
              </h2>
              <p class="mt-4 text-sm leading-6 text-slate-600">{article.description}</p>
              <a class="mt-6 inline-flex items-center gap-2 font-black text-slate-950 transition group-hover:text-enix-red" href={`/blog/${article.slug}/`}>
                Leer artículo <Icon name="chevronRight" class="size-4" />
              </a>
            </article>
          ))}
        </div>
        <div class="mt-12 rounded-3xl bg-enix-ink p-8 text-white">
          <h2 class="text-3xl font-black">¿Quieres aplicar esto a tu empresa?</h2>
          <p class="mt-4 max-w-2xl leading-7 text-slate-300">Un diagnóstico permite priorizar qué mover primero: web, SEO, campañas, automatización, IA o medición.</p>
          <a class="btn btn-primary mt-6" href="/#diagnostico">Solicitar diagnóstico gratuito</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
