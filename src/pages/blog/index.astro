---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import AnimatedHeroBackground from "@/components/hero/AnimatedHeroBackground";
import { blogArticles, blogCategories, categorySlug } from "@/data/blogData";
import { site } from "@/data/site";

const featured = blogArticles[0];
const popular = blogArticles.slice(1, 5);
---

<BaseLayout
  title="Blog SEO para empresas | ENIX STUDIO"
  description="Insights para empresas que quieren crecer con tecnología, marketing, SEO, automatización, IA, diseño web y conversión."
  canonical={`${site.url}/blog/`}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Blog", url: `${site.url}/blog/` }]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:idle />
  <main>
    <section class="motion-reduce-safe relative isolate overflow-hidden bg-[#070b14] pb-20 pt-36 text-white md:pt-44">
      <AnimatedHeroBackground variant="blog" intensity="soft" />
      <div class="container relative z-10 grid gap-10 lg:grid-cols-[1fr_0.72fr] lg:items-end">
        <div>
          <p class="eyebrow">Blog SEO-first</p>
          <h1 class="mt-5 max-w-5xl text-5xl font-black leading-[0.98] md:text-7xl">Insights para empresas que quieren crecer con tecnología, marketing y estrategia.</h1>
          <p class="mt-7 max-w-2xl text-lg leading-8 text-slate-300">Guías prácticas sobre SEO, diseño web, automatización, IA y conversión para tomar mejores decisiones digitales.</p>
          <a class="btn btn-primary mt-8" href="/#diagnostico"><Icon name="search" class="size-5" /> Solicitar diagnóstico gratuito</a>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.055] p-5 backdrop-blur-xl">
          <label class="block text-sm font-black text-white" for="blog-search">Encuentra una guía por tema</label>
          <div class="mt-3 flex items-center gap-3 rounded-2xl border border-white/10 bg-enix-ink/70 px-4 py-3">
            <Icon name="search" class="size-5 text-enix-glow" />
            <input id="blog-search" class="w-full bg-transparent text-sm font-semibold text-white outline-none placeholder:text-slate-500" placeholder="SEO, IA, landing, branding..." />
          </div>
          <div class="mt-5 flex flex-wrap gap-2">
            {blogCategories.map((category) => (
              <a class="rounded-full border border-white/10 bg-white/[0.06] px-3 py-2 text-xs font-black text-slate-300 transition hover:border-enix-red/40 hover:text-white" href={`/blog/categoria/${categorySlug(category)}/`}>
                {category}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container">
        <div class="grid gap-8 lg:grid-cols-[1.25fr_0.75fr]">
          <a href={`/blog/${featured.slug}/`} class="group relative overflow-hidden rounded-[2rem] bg-enix-ink p-8 text-white shadow-premium">
            <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-enix-red/25 blur-3xl transition group-hover:bg-enix-red/35"></div>
            <p class="eyebrow">Artículo destacado</p>
            <h2 class="relative mt-4 max-w-3xl text-4xl font-black md:text-6xl">{featured.title}</h2>
            <p class="relative mt-5 max-w-2xl text-lg leading-8 text-slate-300">{featured.description}</p>
            <div class="relative mt-8 flex flex-wrap gap-3 text-sm font-bold text-slate-300">
              <span>{featured.category}</span><span>·</span><span>{featured.readingTime}</span><span>·</span><span>{featured.updatedAt}</span>
            </div>
          </a>
          <aside class="rounded-[2rem] border border-slate-200 bg-white p-6">
            <h2 class="text-xl font-black">Populares</h2>
            <div class="mt-5 grid gap-4">
              {popular.map((article) => (
                <a class="group border-b border-slate-200 pb-4 last:border-b-0 last:pb-0" href={`/blog/${article.slug}/`}>
                  <span class="text-xs font-black uppercase text-enix-red">{article.category}</span>
                  <h3 class="mt-2 font-black leading-snug group-hover:text-enix-red">{article.title}</h3>
                </a>
              ))}
            </div>
          </aside>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {blogArticles.map((article) => (
            <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-enix-red/30 hover:shadow-premium">
              <a href={`/blog/categoria/${categorySlug(article.category)}/`} class="eyebrow">{article.category}</a>
              <h2 class="mt-3 text-2xl font-black leading-tight group-hover:text-enix-red">
                <a href={`/blog/${article.slug}/`}>{article.title}</a>
              </h2>
              <p class="mt-4 text-sm leading-6 text-slate-600">{article.description}</p>
              <div class="mt-5 flex items-center justify-between text-xs font-bold text-slate-500">
                <span>{article.readingTime}</span>
                <span>{article.updatedAt}</span>
              </div>
              <a class="mt-6 inline-flex items-center gap-2 font-black text-slate-950 transition group-hover:text-enix-red" href={`/blog/${article.slug}/`}>
                Leer artículo <Icon name="chevronRight" class="size-4" />
              </a>
            </article>
          ))}
        </div>

        <div class="mt-14 grid gap-6 rounded-[2rem] bg-enix-ink p-8 text-white lg:grid-cols-[1fr_0.55fr] lg:items-center">
          <div>
            <p class="eyebrow">Diagnóstico recomendado</p>
            <h2 class="mt-3 text-3xl font-black md:text-5xl">Convierte el aprendizaje en una ruta concreta de crecimiento.</h2>
            <p class="mt-4 max-w-2xl leading-7 text-slate-300">Revisamos web, SEO, campañas, CRM, automatización y medición para detectar oportunidades reales.</p>
          </div>
          <a class="btn btn-primary justify-self-start lg:justify-self-end" href="/#diagnostico">Solicitar diagnóstico gratuito</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
