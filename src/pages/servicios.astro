---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import CTAButton from "@/components/CTAButton";
import { capabilityGroups } from "@/data/capabilitiesData";
import { site } from "@/data/site";

const serviceExperiences = [
  {
    icon: "lineChart",
    eyebrow: "Desarrollo web premium",
    title: "Creamos experiencias digitales rápidas, modernas y diseñadas para convertir.",
    pain: "Si tu web se siente lenta, confusa o poco confiable, el cliente decide antes de hablar contigo.",
    outcome: "Más confianza, mejor percepción, SEO técnico, velocidad y rutas claras hacia consulta.",
    metrics: ["Core Web Vitals", "CRO", "SEO base"],
    modal: capabilityGroups[1].modal,
  },
  {
    icon: "search",
    eyebrow: "SEO avanzado",
    title: "Aparece donde tus clientes realmente buscan.",
    pain: "No basta con publicar contenido. La arquitectura, intención, velocidad y autoridad determinan si te encuentran.",
    outcome: "Tráfico más calificado, posicionamiento sostenible y menos dependencia de campañas pagadas.",
    metrics: ["Arquitectura", "Contenido", "Autoridad"],
    modal: capabilityGroups[2].modal,
  },
  {
    icon: "bot",
    eyebrow: "Automatización + IA",
    title: "Atención y seguimiento inteligente 24/7.",
    pain: "Cada consulta sin respuesta rápida puede convertirse en una venta perdida.",
    outcome: "IA para responder, calificar, derivar, activar CRM y mantener seguimiento sin fricción.",
    metrics: ["CRM", "IA", "Flujos"],
    modal: capabilityGroups[3].modal,
  },
  {
    icon: "badgeCheck",
    eyebrow: "Branding estratégico",
    title: "Haz que tu marca se perciba al nivel de la empresa que estás construyendo.",
    pain: "Una marca improvisada baja confianza, precio percibido y diferenciación.",
    outcome: "Identidad, narrativa y dirección visual para transmitir autoridad desde el primer contacto.",
    metrics: ["Confianza", "Posición", "Sistema visual"],
    modal: capabilityGroups[5].modal,
  },
  {
    icon: "megaphone",
    eyebrow: "Paid media",
    title: "No se trata de gastar más. Se trata de convertir mejor.",
    pain: "Campañas sin tracking, landing o seguimiento claro solo compran clics.",
    outcome: "Campañas conectadas a eventos, funnels, landings y oportunidades medibles.",
    metrics: ["ROAS", "Eventos", "Landing"],
    modal: capabilityGroups[2].modal,
  },
  {
    icon: "users",
    eyebrow: "Social media estratégico",
    title: "Transforma presencia social en posicionamiento y demanda.",
    pain: "Publicar por publicar crea movimiento, pero no necesariamente crecimiento.",
    outcome: "Contenido premium, narrativa, captación y consistencia para construir autoridad.",
    metrics: ["Contenido", "Demanda", "Marca"],
    modal: capabilityGroups[2].modal,
  },
];

const comparison = [
  ["Solo diseño", "Estrategia completa conectada a objetivos comerciales"],
  ["Webs lentas", "Performance extrema y experiencia fluida"],
  ["Redes sin dirección", "Posicionamiento y crecimiento medible"],
  ["Campañas sin tracking", "Eventos, funnels y datos accionables"],
  ["Procesos manuales", "CRM, IA y automatización comercial"],
];

const results = [
  ["trending", "+180%", "tráfico potencial"],
  ["users", "+65%", "leads calificados"],
  ["target", "3X", "rutas de conversión"],
  ["bot", "24/7", "automatización activa"],
  ["search", "SEO", "mejor posicionamiento"],
];
---

<BaseLayout
  title="Servicios de growth, IA y automatización | ENIX STUDIO"
  description="ENIX STUDIO diseña sistemas digitales de crecimiento: desarrollo web premium, SEO, paid media, branding, social media, IA, CRM, automatización y analítica."
  canonical={`${site.url}/servicios/`}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Servicios", url: `${site.url}/servicios/` }]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:load />
  <main>
    <section class="noise relative isolate overflow-hidden pb-24 pt-36 text-white md:pt-44">
      <div class="grid-mask absolute inset-0 opacity-70"></div>
      <div class="absolute right-0 top-24 h-96 w-96 rounded-full bg-enix-red/20 blur-3xl"></div>
      <div class="container relative grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="reveal">
          <p class="eyebrow">Servicios ENIX</p>
          <h1 class="mt-5 max-w-5xl text-5xl font-black leading-[0.98] md:text-7xl">No vendemos servicios. Creamos sistemas digitales para crecer.</h1>
          <p class="mt-7 max-w-2xl text-lg leading-8 text-slate-300">
            Cada solución está diseñada para mejorar presencia, conversión, automatización y crecimiento medible.
          </p>
          <a class="btn btn-primary mt-8" href="/#diagnostico"><Icon name="search" class="size-5" /> Solicitar diagnóstico gratuito</a>
        </div>
        <div class="rounded-3xl border border-white/[0.08] bg-white/[0.055] p-4 shadow-[0_30px_100px_rgba(0,0,0,0.32)] backdrop-blur-xl">
          <div class="rounded-2xl border border-white/10 bg-enix-ink/75 p-5">
            <div class="flex items-center justify-between border-b border-white/10 pb-5">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.12em] text-slate-500">Growth system dashboard</p>
                <h2 class="mt-1 text-2xl font-black">Captación · IA · CRM · Datos</h2>
              </div>
              <span class="pulse-dot rounded-full bg-enix-red px-3 py-1 text-xs font-black">Live</span>
            </div>
            <div class="mt-6 grid gap-3 md:grid-cols-2">
              {["Tráfico calificado", "Lead calificado", "CRM actualizado", "Dashboard medido"].map((item, index) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.06] p-4">
                  <Icon name={["megaphone", "target", "briefcase", "barChart"][index]} class="mb-4 size-5 text-enix-glow" />
                  <h3 class="font-black">{item}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-400">{["SEO + campañas", "UX + CRO", "Seguimiento activo", "Optimización continua"][index]}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-enix-pearl py-24">
      <div class="container">
        <p class="eyebrow">Servicios como experiencias</p>
        <h2 class="mt-3 max-w-4xl text-4xl font-black md:text-6xl">Cada capacidad resuelve una pérdida comercial concreta.</h2>
        <div class="mt-12 grid gap-8">
          {serviceExperiences.map((service, index) => (
            <article class={`group grid gap-8 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-enix-red/30 hover:shadow-premium lg:grid-cols-[0.9fr_1.1fr] lg:p-8 ${index % 2 === 1 ? "lg:[&>div:first-child]:order-2" : ""}`}>
              <div class="flex flex-col justify-between">
                <div>
                  <span class="icon-box mb-6"><Icon name={service.icon} class="size-5" /></span>
                  <p class="eyebrow">{service.eyebrow}</p>
                  <h3 class="mt-3 text-3xl font-black leading-tight md:text-5xl">{service.title}</h3>
                  <p class="mt-5 text-lg leading-8 text-slate-600">{service.pain}</p>
                </div>
                <CTAButton
                  client:load
                  context={service.modal}
                  origin="servicios-experiencias"
                  className="btn btn-light mt-7"
                />
              </div>
              <div class="relative overflow-hidden rounded-3xl bg-enix-ink p-6 text-white">
                <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-enix-red/25 blur-3xl transition group-hover:bg-enix-red/35"></div>
                <div class="relative rounded-2xl border border-white/10 bg-white/[0.055] p-5">
                  <p class="text-xs font-black uppercase tracking-[0.12em] text-slate-500">Resultado esperado</p>
                  <h4 class="mt-3 text-2xl font-black">{service.outcome}</h4>
                  <div class="mt-6 grid gap-3 sm:grid-cols-3">
                    {service.metrics.map((metric) => (
                      <div class="rounded-2xl border border-white/10 bg-white/[0.07] p-4 text-center text-sm font-black text-slate-200">{metric}</div>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
        <div>
          <p class="eyebrow">Agencia tradicional vs ENIX</p>
          <h2 class="mt-3 text-4xl font-black md:text-6xl">La diferencia está en conectar diseño, negocio, datos y seguimiento.</h2>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
          {comparison.map(([traditional, enix]) => (
            <div class="grid gap-3 border-b border-slate-200 py-4 last:border-b-0 md:grid-cols-2">
              <div class="rounded-2xl bg-white p-4 font-bold text-slate-500">{traditional}</div>
              <div class="rounded-2xl bg-enix-ink p-4 font-black text-white"><Icon name="check" class="mr-2 inline size-4 text-enix-glow" /> {enix}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-ink text-white">
      <div class="container">
        <p class="eyebrow">Resultados visuales</p>
        <h2 class="mt-3 max-w-4xl text-4xl font-black md:text-6xl">Cuando el sistema se conecta, la empresa deja de improvisar su crecimiento.</h2>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
          {results.map(([icon, value, label]) => (
            <article class="rounded-2xl border border-white/10 bg-white/[0.055] p-6">
              <Icon name={icon} class="mb-5 size-6 text-enix-glow" />
              <strong class="block text-4xl font-black">{value}</strong>
              <span class="mt-2 block text-sm font-semibold text-slate-400">{label}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="noise section text-white">
      <div class="container text-center">
        <p class="eyebrow">Decisión estratégica</p>
        <h2 class="mx-auto mt-4 max-w-5xl text-4xl font-black md:text-6xl">La presencia digital correcta puede cambiar completamente cómo tu empresa es percibida.</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          No necesitas parecer una empresa pequeña solo porque tu experiencia digital aún no está al nivel de tu negocio.
        </p>
        <a class="btn btn-primary mt-8" href="/#diagnostico"><Icon name="arrowUp" class="size-5" /> Solicitar diagnóstico gratuito</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
