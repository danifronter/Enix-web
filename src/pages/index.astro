---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import FormSubmitScript from "@/components/FormSubmitScript.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import HeroGrowthOS from "@/components/HeroGrowthOS";
import GrowthSystemSection from "@/components/GrowthSystemSection";
import GuidedDiagnosticSection from "@/components/GuidedDiagnosticSection";
import { blogArticles } from "@/data/blogData";
import { site } from "@/data/site";

const problems = [
  ["shield", "Web que no genera confianza", "Tu empresa parece menos sólida de lo que realmente es."],
  ["megaphone", "Redes que no convierten", "Hay movimiento, pero no una ruta clara hacia ventas."],
  ["barChart", "Campañas sin medición real", "Inviertes sin saber qué genera oportunidades."],
  ["briefcase", "Leads sin seguimiento", "Consultas valiosas se enfrían antes de cerrar."],
  ["search", "SEO débil o inexistente", "Tus clientes buscan, pero encuentran a otros primero."],
];

const capabilities = [
  ["lineChart", "Desarrollo Web Premium", "Sitios rápidos, modernos y diseñados para convertir visitas en oportunidades.", ["UX/UI", "SEO técnico", "Performance"], "/servicios/desarrollo-web/", "Ver desarrollo web"],
  ["search", "SEO Avanzado", "Posicionamiento orgánico para aparecer cuando tus clientes buscan soluciones.", ["SEO técnico", "Contenido", "Arquitectura"], "/servicios/seo/", "Ver SEO"],
  ["bot", "Automatización e IA", "Procesos inteligentes para responder, filtrar y dar seguimiento sin perder leads.", ["Chatbots", "CRM", "Flujos"], "/servicios/automatizacion-ia/", "Ver automatización"],
  ["megaphone", "Paid Media", "Campañas con medición real, enfocadas en oportunidades y conversión.", ["Google Ads", "Meta Ads", "Tracking"], "/servicios/paid-media/", "Ver campañas"],
  ["badgeCheck", "Branding", "Identidad y comunicación para transmitir confianza desde el primer contacto.", ["Marca", "Mensaje", "Sistema visual"], "/servicios/branding/", "Ver branding"],
  ["barChart", "Analítica y Tracking", "Datos claros para saber qué funciona, qué no y dónde optimizar.", ["GA4", "GTM", "Eventos"], "/servicios/analitica-tracking/", "Ver analítica"],
];

const proofCases = [
  ["lineChart", "Web corporativa que no convertía", "Mensaje más claro, experiencia premium y mejor ruta de contacto.", "/casos/rediseno-web-corporativo-empresa-servicios/"],
  ["target", "Campañas sin resultados claros", "Landing, tracking y medición para entender qué generaba oportunidades.", "/casos/landing-page-captacion-leads/"],
  ["bot", "Atención manual y lenta", "Automatización inicial para responder y ordenar solicitudes.", "/casos/automatizacion-comercial-crm-ia/"],
];

const featuredInsights = [
  {
    slug: "por-que-tu-pagina-web-no-genera-clientes",
    category: "Conversión",
    excerpt: "Errores que hacen que una web reciba visitas, pero no genere oportunidades reales.",
    icon: "lineChart",
  },
  {
    slug: "seo-para-empresas",
    category: "SEO",
    excerpt: "Cómo estructurar tu sitio para atraer tráfico con intención comercial.",
    icon: "search",
  },
  {
    slug: "automatizacion-comercial",
    category: "Automatización",
    excerpt: "CRM, WhatsApp e IA para responder más rápido y vender mejor.",
    icon: "bot",
  },
].map((item) => ({ ...item, article: blogArticles.find((article) => article.slug === item.slug)! }));

const trustSignals = [
  ["zap", "Webs rápidas y preparadas para SEO"],
  ["target", "Estrategia digital antes que diseño"],
  ["bot", "Automatización e IA aplicada a ventas"],
  ["barChart", "Campañas con tracking y datos reales"],
  ["activity", "Optimización continua basada en evidencia"],
];

const homeFaqs: [string, string][] = [
  ["¿Qué servicio necesito si no sé por dónde empezar?", "Lo mejor es partir con un diagnóstico. Revisamos tu situación y priorizamos web, SEO, campañas, automatización o estrategia según impacto."],
  ["¿Pueden mejorar una web que ya tengo?", "Sí. Podemos auditar claridad, velocidad, SEO, conversión y seguimiento antes de decidir si conviene optimizar o rediseñar."],
  ["¿El diagnóstico gratuito tiene costo?", "No. Es una revisión inicial para detectar oportunidades y definir el siguiente paso con más claridad."],
  ["¿Trabajan solo con empresas grandes?", "No. Trabajamos con empresas que quieren verse más profesionales, captar mejor y ordenar su crecimiento digital."],
];
---

<BaseLayout
  title="Enix Studio | Marketing, Web, SEO y Automatización para Empresas"
  description="Agencia digital de NOVVOR especializada en desarrollo web, SEO, automatización, IA, campañas y estrategia digital para empresas que quieren crecer."
  canonical={site.url}
  faqItems={homeFaqs}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:idle />
  <main>
    <HeroGrowthOS client:load />

    <section id="problema" class="section scroll-mt-16 bg-white">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Problema</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Tu empresa puede estar perdiendo clientes antes de hablar con ellos.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Muchas veces el problema no es el producto. Es la experiencia digital que el cliente encuentra antes de decidir.
          </p>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
          {problems.map(([icon, title, text]) => (
            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white hover:shadow-premium">
              <span class="icon-box mb-5"><Icon name={icon} class="size-5" /></span>
              <h3 class="text-lg font-black">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <GrowthSystemSection client:visible />

    <section id="servicios" class="section scroll-mt-16 bg-enix-pearl">
      <div class="container">
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-3xl">
            <p class="eyebrow">Capacidades</p>
            <h2 class="mt-3 text-4xl font-black md:text-5xl">Capacidades para atraer, convertir y escalar.</h2>
          </div>
          <a class="btn btn-light" href="/servicios/">Ver servicios</a>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {capabilities.map(([icon, title, benefit, modules, href, cta]) => (
            <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-enix-red/30 hover:shadow-premium">
              <span class="icon-box mb-5"><Icon name={icon as string} class="size-5" /></span>
              <h3 class="text-2xl font-black">{title}</h3>
              <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">{benefit}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {(modules as string[]).map((module) => <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600">{module}</span>)}
              </div>
              <a class="mt-6 inline-flex items-center gap-2 font-black text-slate-950 transition group-hover:text-enix-red" href={href as string}>
                {cta} <Icon name="chevronRight" class="size-4" />
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <GuidedDiagnosticSection client:visible />

    <section id="resultados" class="section scroll-mt-16 bg-enix-ink text-white">
      <div class="container">
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-3xl">
            <p class="eyebrow">Casos y autoridad</p>
            <h2 class="mt-3 text-4xl font-black md:text-5xl">Soluciones diseñadas para problemas reales.</h2>
          </div>
          <a class="btn btn-secondary" href="/casos/">Ver casos y soluciones</a>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {proofCases.map(([icon, title, result, href]) => (
            <a href={href} class="group rounded-2xl border border-white/10 bg-white/[0.055] p-6 transition hover:-translate-y-1 hover:border-enix-red/40 hover:bg-white/[0.08]">
              <span class="mb-5 grid size-11 place-items-center rounded-xl bg-enix-red/15 text-enix-glow"><Icon name={icon} class="size-5" /></span>
              <h3 class="text-2xl font-black group-hover:text-enix-glow">{title}</h3>
              <p class="mt-4 text-sm leading-6 text-slate-400">{result}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="insights" class="section scroll-mt-16 bg-enix-pearl">
      <div class="container">
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-3xl">
            <p class="eyebrow">Insights</p>
            <h2 class="mt-3 text-4xl font-black md:text-5xl">Insights para tomar mejores decisiones digitales.</h2>
            <p class="mt-5 text-lg leading-8 text-slate-600">Contenido práctico para entender qué está frenando tu crecimiento antes de invertir más.</p>
          </div>
          <a class="btn btn-light" href="/blog/">Ver todos los insights</a>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {featuredInsights.map(({ article, category, excerpt, icon }) => (
            <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-enix-red/30 hover:shadow-premium">
              <div class="mb-6 flex items-center justify-between gap-4">
                <span class="icon-box"><Icon name={icon} class="size-5" /></span>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-500">{article.readingTime}</span>
              </div>
              <p class="eyebrow">{category}</p>
              <h3 class="mt-3 text-2xl font-black leading-tight group-hover:text-enix-red">
                <a href={`/blog/${article.slug}/`}>{article.title.replace(" Errores que están frenando tus ventas", "")}</a>
              </h3>
              <p class="mt-4 text-sm leading-6 text-slate-600">{excerpt}</p>
              <a class="mt-6 inline-flex items-center gap-2 font-black text-slate-950 transition group-hover:text-enix-red" href={`/blog/${article.slug}/`}>
                Leer artículo <Icon name="chevronRight" class="size-4" />
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="eyebrow">FAQ</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Preguntas antes de avanzar.</h2>
        </div>
        <div class="space-y-3">
          {homeFaqs.map(([question, answer]) => (
            <details class="rounded-lg border border-slate-200 bg-white p-5">
              <summary class="flex cursor-pointer items-center gap-3 font-black"><Icon name="message" class="size-5 text-enix-red" /> {question}</summary>
              <p class="mt-3 leading-7 text-slate-600">{answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-enix-ink py-10 text-white">
      <div class="container">
        <h2 class="max-w-3xl text-3xl font-black">Diseñado para empresas que quieren verse mejor, vender mejor y operar mejor.</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
          {trustSignals.map(([icon, label]) => (
            <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.055] p-4">
              <Icon name={icon} class="size-5 shrink-0 text-enix-glow" />
              <span class="text-sm font-black leading-5 text-slate-200">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="diagnostico" class="noise section scroll-mt-16 text-white">
      <div class="container grid items-center gap-10 lg:grid-cols-[1fr_0.75fr]">
        <div>
          <p class="eyebrow">CTA final</p>
          <h2 class="mt-3 text-4xl font-black leading-tight md:text-6xl">Antes de invertir más en marketing, descubre qué está frenando tus resultados.</h2>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">Analizamos tu presencia digital y detectamos oportunidades concretas para mejorar visibilidad, confianza y conversión.</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn btn-primary" href="/diagnostico/">Solicitar diagnóstico gratuito</a>
            <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
          </div>
        </div>
        <form class="glass rounded-2xl p-6" name="diagnostico" method="post" data-enix-form>
          <input type="hidden" name="type" value="diagnostic" />
          <input type="hidden" name="form-name" value="diagnostico" />
          <input type="hidden" name="origen" value="home-cta-final" />
          <label class="block text-sm font-extrabold">Nombre<input class="mt-2 w-full rounded-lg border border-white/10 bg-white/10 px-4 py-3 text-white outline-none focus:border-enix-glow" name="nombre" autocomplete="name" required /></label>
          <label class="mt-4 block text-sm font-extrabold">Email<input class="mt-2 w-full rounded-lg border border-white/10 bg-white/10 px-4 py-3 text-white outline-none focus:border-enix-glow" name="email" type="email" autocomplete="email" required /></label>
          <label class="mt-4 block text-sm font-extrabold">¿Qué quieres mejorar?<textarea class="mt-2 min-h-28 w-full rounded-lg border border-white/10 bg-white/10 px-4 py-3 text-white outline-none focus:border-enix-glow" name="mensaje" required></textarea></label>
          <label class="mt-4 flex gap-3 text-xs font-semibold leading-5 text-slate-400">
            <input class="mt-1 h-4 w-4 rounded border-white/20 bg-transparent accent-enix-red" type="checkbox" name="consent" required />
            <span>Acepto ser contactado por Enix Studio para responder mi solicitud.</span>
          </label>
          <button class="btn btn-primary mt-5 w-full" type="submit"><Icon name="arrowUp" class="size-5" /> Solicitar diagnóstico gratuito</button>
          <p class="mt-3 rounded-xl px-3 py-2 text-center text-sm font-bold empty:hidden data-[state=error]:border data-[state=error]:border-red-400/30 data-[state=error]:bg-red-500/10 data-[state=error]:text-red-100 data-[state=success]:border data-[state=success]:border-emerald-400/30 data-[state=success]:bg-emerald-500/10 data-[state=success]:text-emerald-100" data-form-status aria-live="polite"></p>
          <p class="mt-3 text-center text-xs font-semibold leading-5 text-slate-500">
            Al enviar aceptas nuestra <a class="font-black text-red-300 hover:underline" href="/politica-de-privacidad/">Política de Privacidad</a>.
          </p>
        </form>
      </div>
    </section>
  </main>
  <Footer />
  <FormSubmitScript />
</BaseLayout>
