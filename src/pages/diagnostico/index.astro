---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import FormSubmitScript from "@/components/FormSubmitScript.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import AnimatedHeroBackground from "@/components/hero/AnimatedHeroBackground";
import { site } from "@/data/site";

const canonical = `${site.url}/diagnostico/`;

const improveOptions = [
  ["lineChart", "Mi web no vende", "conversion"],
  ["search", "Quiero aparecer en Google", "seo"],
  ["megaphone", "Estoy invirtiendo en publicidad", "paid-media"],
  ["bot", "Quiero automatizar atención", "automatizacion"],
  ["globe", "No tengo web", "web"],
  ["target", "Necesito una estrategia completa", "estrategia"],
];

const trustItems = [
  ["message", "Respuesta inicial clara"],
  ["check", "Sin compromiso"],
  ["target", "Enfoque estratégico"],
  ["shield", "Datos protegidos"],
  ["badgeCheck", "Agencia digital de NOVVOR"],
];

const nextSteps = [
  ["search", "Revisamos tu situación", "Analizamos tu problema, sitio web o presencia digital."],
  ["radar", "Detectamos oportunidades", "Identificamos puntos que podrían afectar visibilidad, confianza o conversión."],
  ["target", "Te recomendamos un camino", "Te indicamos si conviene partir por web, SEO, campañas, automatización o estrategia."],
  ["message", "Si hace sentido, agendamos", "Solo si vemos una oportunidad clara, coordinamos una reunión."],
];

const symptomCards = [
  ["lineChart", "Pocas consultas", "Revisar conversión"],
  ["search", "No apareces en Google", "Revisar SEO"],
  ["barChart", "Publicidad sin claridad", "Revisar tracking y landing"],
  ["bot", "Leads sin respuesta", "Revisar automatización"],
  ["badgeCheck", "Marca poco profesional", "Revisar branding y web"],
];

const serviceLinks = [
  ["Desarrollo Web y Plataformas Digitales", "/servicios/desarrollo-web/"],
  ["SEO Avanzado", "/servicios/seo/"],
  ["Paid Media", "/servicios/paid-media/"],
  ["Automatización e IA", "/servicios/automatizacion-ia/"],
  ["Branding", "/servicios/branding/"],
  ["Analítica y Tracking", "/servicios/analitica-tracking/"],
];

const diagnosticFaqs: [string, string][] = [
  ["¿El diagnóstico tiene costo?", "No. Es una orientación inicial gratuita para entender tu caso."],
  ["¿Me van a vender algo de inmediato?", "No. Primero revisamos tu situación y te sugerimos un camino lógico."],
  ["¿Necesito tener una web?", "No. Podemos orientarte tanto si ya tienes web como si estás partiendo."],
  ["¿Cuánto tardan en responder?", "Normalmente respondemos dentro de un plazo breve en horario hábil."],
];

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Diagnóstico Digital Gratuito | Enix Studio",
  url: canonical,
  description:
    "Solicita un diagnóstico digital gratuito con Enix Studio para revisar web, SEO, campañas, automatización o presencia digital.",
  mainEntity: {
    "@type": "Organization",
    name: site.name,
    email: site.email,
    url: site.url,
  },
};
---

<BaseLayout
  title="Diagnóstico Digital Gratuito | Enix Studio"
  description="Solicita un diagnóstico digital gratuito con Enix Studio. Revisamos tu web, SEO, campañas, automatización o presencia digital y te orientamos con una recomendación inicial."
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Diagnóstico", url: canonical }]}
  faqItems={diagnosticFaqs}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:idle />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <main>
    <section id="top" class="motion-reduce-safe relative isolate overflow-hidden bg-[#070b14] pb-20 pt-36 text-white md:pt-44">
      <AnimatedHeroBackground variant="diagnostic" intensity="strong" />
      <div class="container relative z-10 grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/[0.07] px-4 py-2 text-xs font-black uppercase text-red-100">
            <span class="size-2 rounded-full bg-enix-glow shadow-[0_0_18px_rgba(239,68,68,0.85)]"></span>
            Diagnóstico gratuito · Agencia digital de NOVVOR
          </p>
          <h1 class="mt-6 max-w-4xl text-[clamp(2.1rem,3.5vw,3.55rem)] font-black leading-[1.03] tracking-tight">
            Descubre qué está frenando tus resultados digitales.
          </h1>
          <p class="mt-7 max-w-2xl text-lg leading-8 text-slate-300">
            Analizamos tu situación y te mostramos por dónde empezar para atraer más clientes, convertir mejor y ordenar tu presencia digital.
          </p>
          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            {[
              "Web, SEO, campañas, IA o automatización",
              "Recomendación inicial sin compromiso",
              "Respuesta clara y accionable",
              "Enfoque en oportunidades reales",
            ].map((item) => (
              <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.055] px-4 py-3 text-sm font-bold text-slate-200">
                <span class="grid size-8 shrink-0 place-items-center rounded-xl bg-enix-red/15 text-enix-glow"><Icon name="check" class="size-4" /></span>
                {item}
              </div>
            ))}
          </div>
          <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
            {trustItems.map(([icon, item]) => (
              <div class="flex items-center gap-3 text-sm font-bold text-slate-300">
                <span class="grid size-9 shrink-0 place-items-center rounded-xl border border-white/10 bg-white/[0.05] text-red-200"><Icon name={icon} class="size-4" /></span>
                {item}
              </div>
            ))}
          </div>
        </div>

        <form class="relative overflow-hidden rounded-[2rem] border border-white/12 bg-white/[0.065] p-5 shadow-2xl shadow-black/35 backdrop-blur-2xl md:p-7" name="diagnostico" method="post" data-enix-form>
          <div class="absolute -right-20 -top-20 h-56 w-56 rounded-full bg-enix-red/15 blur-3xl"></div>
          <div class="relative">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-red-300">Solicita una orientación inicial sin compromiso</p>
            <h2 class="mt-3 text-3xl font-black text-white">Cuéntanos qué quieres mejorar</h2>
            <p class="mt-3 text-sm leading-6 text-slate-400">Sin compromiso. Sin venta agresiva. Primero entendemos tu caso.</p>

            <input type="hidden" name="type" value="diagnostic" />
            <input type="hidden" name="form-name" value="diagnostico" />
            <input type="hidden" name="origen" value="pagina-diagnostico" />

            <fieldset class="mt-6">
              <legend class="text-sm font-black text-slate-200">¿Qué quieres mejorar?</legend>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                {improveOptions.map(([icon, label, value], index) => (
                  <label class="group cursor-pointer">
                    <input class="peer sr-only" type="radio" name="necesidad" value={value} required checked={index === 0} />
                    <span class="flex min-h-16 items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.045] px-4 py-3 text-sm font-black text-slate-200 transition peer-checked:border-red-300/70 peer-checked:bg-red-600/20 peer-checked:text-white hover:border-red-300/50 hover:bg-red-500/10">
                      <span class="grid size-10 shrink-0 place-items-center rounded-xl bg-white/10 text-red-300"><Icon name={icon} class="size-5" /></span>
                      {label}
                    </span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="mt-5 grid gap-4 md:grid-cols-2">
              <label class="block text-sm font-extrabold text-slate-200">
                Nombre
                <input class="mt-2 w-full rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 text-white outline-none transition placeholder:text-slate-500 focus:border-enix-glow focus:ring-2 focus:ring-red-400/20" name="nombre" autocomplete="name" placeholder="Tu nombre" required />
              </label>
              <label class="block text-sm font-extrabold text-slate-200">
                Email
                <input class="mt-2 w-full rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 text-white outline-none transition placeholder:text-slate-500 focus:border-enix-glow focus:ring-2 focus:ring-red-400/20" name="email" type="email" autocomplete="email" placeholder="correo@empresa.cl" required />
              </label>
              <label class="block text-sm font-extrabold text-slate-200">
                Teléfono <span class="font-semibold text-slate-500">opcional</span>
                <input class="mt-2 w-full rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 text-white outline-none transition placeholder:text-slate-500 focus:border-enix-glow focus:ring-2 focus:ring-red-400/20" name="whatsapp" autocomplete="tel" placeholder="+56 9..." />
              </label>
              <label class="block text-sm font-extrabold text-slate-200">
                Sitio web <span class="font-semibold text-slate-500">opcional</span>
                <input class="mt-2 w-full rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 text-white outline-none transition placeholder:text-slate-500 focus:border-enix-glow focus:ring-2 focus:ring-red-400/20" name="sitio" inputmode="url" placeholder="https://tuempresa.cl" />
              </label>
            </div>

            <label class="mt-5 block text-sm font-extrabold text-slate-200">
              Cuéntanos brevemente qué está pasando <span class="font-semibold text-slate-500">opcional</span>
              <textarea class="mt-2 min-h-28 w-full rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 text-white outline-none transition placeholder:text-slate-500 focus:border-enix-glow focus:ring-2 focus:ring-red-400/20" name="mensaje" placeholder="Ej: Tengo una web, pero no recibo consultas. Hago publicaciones, pero no sé si generan clientes..."></textarea>
            </label>

            <label class="mt-5 flex gap-3 text-sm font-semibold leading-6 text-slate-400">
              <input class="mt-1 h-4 w-4 rounded border-white/20 bg-transparent accent-enix-red" type="checkbox" name="consent" required />
              <span>Acepto ser contactado por Enix Studio para responder mi solicitud.</span>
            </label>

            <button class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-full bg-enix-red px-7 py-4 text-sm font-black text-white shadow-xl shadow-red-950/40 transition hover:-translate-y-0.5 hover:bg-red-500" type="submit">
              <Icon name="arrowUp" class="size-5" /> Solicitar diagnóstico gratuito
            </button>
            <p class="mt-3 rounded-xl px-3 py-2 text-center text-sm font-bold empty:hidden data-[state=error]:border data-[state=error]:border-red-400/30 data-[state=error]:bg-red-500/10 data-[state=error]:text-red-100 data-[state=success]:border data-[state=success]:border-emerald-400/30 data-[state=success]:bg-emerald-500/10 data-[state=success]:text-emerald-100" data-form-status aria-live="polite"></p>
            <p class="mt-3 text-center text-xs font-semibold leading-5 text-slate-500">
              Te responderemos con una orientación inicial. No compartimos tus datos. Al enviar aceptas nuestra
              <a class="font-black text-red-300 hover:underline" href="/politica-de-privacidad/"> Política de Privacidad</a>. Registramos datos técnicos del envío para prevenir spam y proteger nuestras comunicaciones.
            </p>
          </div>
        </form>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div>
          <p class="eyebrow">Después de enviar</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">¿Qué pasa después de enviar tu solicitud?</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">El diagnóstico baja la ansiedad porque deja claro qué revisamos, qué puedes esperar y cuándo tiene sentido avanzar.</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {nextSteps.map(([icon, title, text], index) => (
            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
              <span class="text-xs font-black text-enix-red">0{index + 1}</span>
              <span class="mt-4 grid size-11 place-items-center rounded-xl bg-red-50 text-enix-red"><Icon name={icon} class="size-5" /></span>
              <h3 class="mt-5 text-xl font-black">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Orientación</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">No necesitas saber qué servicio contratar.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">Muchas empresas llegan con síntomas. Nosotros ayudamos a identificar qué revisar primero.</p>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-5">
          {symptomCards.map(([icon, symptom, action]) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <span class="icon-box mb-5"><Icon name={icon} class="size-5" /></span>
              <h3 class="text-lg font-black">{symptom}</h3>
              <p class="mt-3 text-sm font-bold text-enix-red">{action}</p>
            </article>
          ))}
        </div>
        <a class="btn btn-primary mt-10" href="#top"><Icon name="radar" class="size-5" /> Quiero que revisen mi caso</a>
      </div>
    </section>

    <section class="section bg-enix-ink text-white">
      <div class="container grid gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:items-center">
        <div>
          <p class="eyebrow">Criterio antes que venta</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Un diagnóstico orientado a decisiones, no a venderte cualquier cosa.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-300">Si tu problema está en SEO, no te venderemos una campaña primero. Si tu web no convierte, no tiene sentido aumentar presupuesto sin corregir la base.</p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {serviceLinks.map(([label, href]) => (
            <a class="group flex items-center justify-between rounded-2xl border border-white/10 bg-white/[0.055] p-5 font-black text-white transition hover:-translate-y-1 hover:border-red-300/50 hover:bg-red-500/10" href={href}>
              {label}
              <Icon name="chevronRight" class="size-5 text-red-300 transition group-hover:translate-x-1" />
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Preguntas frecuentes</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Dudas normales antes de pedir un diagnóstico.</h2>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {diagnosticFaqs.map(([question, answer]) => (
            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
              <h3 class="text-xl font-black">{question}</h3>
              <p class="mt-3 leading-7 text-slate-600">{answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-red text-white">
      <div class="container grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-4xl font-black md:text-5xl">Pregunta sin tener todo resuelto.</h2>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-red-50">Te ayudamos a entender por dónde empezar y qué no conviene hacer todavía.</p>
        </div>
        <a class="rounded-full bg-white px-7 py-4 text-sm font-black text-enix-red shadow-xl transition hover:-translate-y-0.5" href="#top">Solicitar diagnóstico</a>
      </div>
    </section>
  </main>
  <Footer />
  <FormSubmitScript />
</BaseLayout>
