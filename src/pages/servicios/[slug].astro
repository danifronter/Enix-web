---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import AnimatedHeroBackground from "@/components/hero/AnimatedHeroBackground";
import { servicePages } from "@/data/servicePagesData";
import { site } from "@/data/site";

export const prerender = true;

export function getStaticPaths() {
  return servicePages.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const canonical = `${site.url}/servicios/${service.slug}/`;
---

<BaseLayout
  title={`${service.title} | ENIX STUDIO`}
  description={`${service.description} Servicio de ENIX STUDIO para empresas que quieren mejorar visibilidad, confianza y conversión.`}
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Servicios", url: `${site.url}/servicios/` }, { name: service.title, url: canonical }]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:idle />
  <main>
    <section class="motion-reduce-safe relative isolate overflow-hidden bg-[#070b14] pb-20 pt-36 text-white md:pt-44">
      <AnimatedHeroBackground variant="services" intensity="medium" />
      <div class="container relative z-10 grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="eyebrow">Servicio</p>
          <h1 class="mt-5 max-w-4xl text-5xl font-black leading-[0.98] md:text-7xl">{service.title}</h1>
          <p class="mt-7 max-w-2xl text-lg leading-8 text-slate-300">{service.description}</p>
          <a class="btn btn-primary mt-8" href={`/diagnostico/?servicio=${service.slug}`}><Icon name="search" class="size-5" /> Solicitar diagnóstico</a>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.055] p-6 backdrop-blur-xl">
          <span class="grid size-14 place-items-center rounded-2xl bg-enix-red/15 text-enix-glow"><Icon name={service.icon} class="size-7" /></span>
          <h2 class="mt-6 text-3xl font-black">Qué incluye</h2>
          <div class="mt-5 flex flex-wrap gap-2">
            {service.modules.map((module) => <span class="rounded-full border border-white/10 bg-white/[0.06] px-4 py-2 text-sm font-black">{module}</span>)}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
