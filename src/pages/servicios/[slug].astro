---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import ServiceHero from "@/components/services/ServiceHero";
import type { ServiceVisualVariant } from "@/components/services/ServiceHeroVisual";
import { servicePages, type ServicePage } from "@/data/servicePagesData";
import { site } from "@/data/site";

export const prerender = true;

export function getStaticPaths() {
  return servicePages.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props as { service: ServicePage };
const canonical = `${site.url}/servicios/${service.slug}/`;
const isWebService = service.slug === "desarrollo-web";
const relatedServices = service.related
  .map((slug) => servicePages.find((item) => item.slug === slug))
  .filter((item): item is ServicePage => Boolean(item));

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.title,
  description: service.metaDescription,
  provider: {
    "@type": "Organization",
    name: site.name,
    url: site.url,
    email: site.email,
  },
  areaServed: "Chile",
  serviceType: service.title,
  url: canonical,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: service.faq.map(([question, answer]) => ({
    "@type": "Question",
    name: question,
    acceptedAnswer: { "@type": "Answer", text: answer },
  })),
};

const webSolutionCards = [
  ["Web corporativa", "Para empresas B2B y servicios profesionales.", "Transmite confianza y convierte visitas en solicitudes."],
  ["Landing page", "Para campanas, lanzamientos o servicios especificos.", "Reduce friccion y enfoca al usuario en una accion."],
  ["Ecommerce", "Para vender productos o servicios online.", "Conecta catalogo, compra, medicion y optimizacion."],
  ["Catalogo digital", "Para empresas con oferta amplia o tecnica.", "Ordena productos, fichas, categorias y consultas."],
  ["Portal de clientes", "Para soporte, documentos o seguimiento.", "Mejora la experiencia posterior a la venta."],
  ["Plataforma interna", "Para procesos, solicitudes o gestion.", "Reduce tareas manuales y centraliza operaciones."],
  ["Blog SEO", "Para autoridad, contenido y busquedas organicas.", "Atrae demanda con intencion real."],
  ["Reservas o solicitudes", "Para servicios con agenda o evaluacion previa.", "Ordena disponibilidad, requisitos y captacion."],
];

const webScenarios = [
  ["Empresa B2B de servicios", "Necesita transmitir confianza y recibir solicitudes de cotizacion."],
  ["Proveedor industrial", "Necesita mostrar servicios tecnicos, certificaciones y formularios claros."],
  ["Ecommerce", "Necesita vender productos, medir conversiones y recuperar clientes."],
  ["Institucion o academia", "Necesita informar programas, captar inscritos y automatizar consultas."],
  ["Consultora profesional", "Necesita autoridad, contenido SEO y agenda de reuniones."],
];

const webTimeline = [
  "Diagnostico y objetivos",
  "Arquitectura y contenido",
  "Diseno UX/UI",
  "Desarrollo",
  "SEO tecnico y performance",
  "Integraciones y formularios",
  "Testing mobile",
  "Lanzamiento y medicion",
];

const webTechnologies = ["Astro", "WordPress", "WooCommerce", "Shopify", "React", "Tailwind", "Cloudflare", "Vercel", "GA4", "GTM", "Resend", "Supabase", "OpenAI"];

type HeroConfig = {
  badge: string;
  title: string;
  description: string;
  benefits: string[];
  visual: ServiceVisualVariant;
  cta: string;
};

const heroBySlug: Record<string, HeroConfig> = {
  "desarrollo-web": {
    badge: "Desarrollo Web",
    title: "Webs y plataformas digitales pensadas para vender, operar y crecer.",
    description:
      "Creamos sitios, ecommerce y plataformas rapidas, claras y conectadas a SEO, formularios, analitica y automatizacion.",
    benefits: ["Webs rapidas y responsive", "Formularios y WhatsApp conectados", "SEO tecnico y medicion desde el inicio"],
    visual: "web",
    cta: "Revisar mi proyecto web",
  },
  seo: {
    badge: "SEO Avanzado",
    title: "Haz que tus clientes te encuentren cuando ya estan buscando.",
    description:
      "Ordenamos la estructura, contenido y senales tecnicas de tu sitio para mejorar visibilidad organica y captar trafico con intencion real.",
    benefits: ["Arquitectura SEO clara", "Contenido orientado a busqueda", "Mejor base tecnica para Google"],
    visual: "seo",
    cta: "Revisar mi posicionamiento",
  },
  "paid-media": {
    badge: "Paid Media",
    title: "Campanas digitales con estrategia, medicion y foco en oportunidades.",
    description:
      "Creamos campanas conectadas a landing pages, eventos y datos para entender que canal genera resultados.",
    benefits: ["Google Ads y Meta Ads", "Landing y tracking conectado", "Optimizacion basada en datos"],
    visual: "paid",
    cta: "Revisar mis campanas",
  },
  "automatizacion-ia": {
    badge: "Automatizacion e IA",
    title: "Responde, clasifica y sigue oportunidades sin perder clientes.",
    description:
      "Conectamos formularios, WhatsApp, CRM, correos e IA para ordenar la atencion y seguimiento comercial.",
    benefits: ["Leads centralizados", "Respuestas y flujos automaticos", "IA como apoyo, no reemplazo humano"],
    visual: "automation",
    cta: "Revisar mi seguimiento",
  },
  branding: {
    badge: "Branding",
    title: "Haz que tu empresa transmita confianza antes de vender.",
    description:
      "Construimos identidad, mensaje y sistema visual para que tu marca se vea clara, profesional y coherente.",
    benefits: ["Identidad visual profesional", "Mensaje comercial claro", "Coherencia en web, redes y campanas"],
    visual: "branding",
    cta: "Revisar mi marca",
  },
  "analitica-tracking": {
    badge: "Analitica y Tracking",
    title: "Mide lo que importa antes de seguir invirtiendo.",
    description:
      "Configuramos eventos, conversiones y dashboards para saber que paginas, campanas y canales generan oportunidades.",
    benefits: ["GA4 y GTM ordenados", "Eventos de formularios y WhatsApp", "Dashboard claro para decidir"],
    visual: "analytics",
    cta: "Revisar mi medicion",
  },
};

const hero = heroBySlug[service.slug] ?? {
  badge: service.shortTitle,
  title: service.h1,
  description: service.heroSubtitle,
  benefits: service.modules.slice(0, 3),
  visual: "web" as ServiceVisualVariant,
  cta: service.cta,
};
---

<BaseLayout
  title={service.seoTitle}
  description={service.metaDescription}
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Servicios", url: `${site.url}/servicios/` }, { name: service.title, url: canonical }]}
  faqItems={service.faq}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:idle />
  <main>
    <ServiceHero
      client:visible
      badge={hero.badge}
      title={hero.title}
      description={hero.description}
      benefits={hero.benefits}
      service={service.title}
      visual={hero.visual}
      cta={hero.cta}
    />
    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
        <div>
          <p class="eyebrow">Antes y después</p>
          <h2 class="mt-3 text-4xl font-black leading-tight md:text-5xl">El valor no está en “hacer algo”. Está en corregir lo que frena la decisión.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">{service.description}</p>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          <article class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-slate-500">Antes</p>
            <h3 class="mt-3 text-2xl font-black">Piezas débiles o desconectadas</h3>
            <div class="mt-6 grid gap-3">
              {service.before.map((item) => (
                <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700">
                  <span class="size-2 shrink-0 rounded-full bg-slate-400"></span>
                  {item}
                </div>
              ))}
            </div>
          </article>
          <article class="rounded-[2rem] border border-red-200 bg-gradient-to-br from-red-50 to-white p-6 shadow-xl shadow-red-100/60">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-enix-red">Después</p>
            <h3 class="mt-3 text-2xl font-black">Sistema claro y medible</h3>
            <div class="mt-6 grid gap-3">
              {service.after.map((item) => (
                <div class="flex items-center gap-3 rounded-2xl border border-red-100 bg-white px-4 py-3 text-sm font-bold text-slate-800">
                  <Icon name="check" class="size-4 shrink-0 text-enix-red" />
                  {item}
                </div>
              ))}
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Qué incluye</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Entregables pensados para resolver, no para decorar una propuesta.</h2>
        </div>
        <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {service.includes.map((item) => (
            <div class="flex min-h-20 items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:border-red-200 hover:shadow-xl hover:shadow-red-100/50">
              <span class="grid size-10 shrink-0 place-items-center rounded-xl bg-red-50 text-enix-red"><Icon name="check" class="size-5" /></span>
              <span class="text-sm font-black text-slate-900">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {isWebService && (
      <section class="section bg-white">
        <div class="container">
          <div class="max-w-3xl">
            <p class="eyebrow">Que podemos construir</p>
            <h2 class="mt-3 text-4xl font-black md:text-5xl">No todas las empresas necesitan la misma web.</h2>
            <p class="mt-5 text-lg leading-8 text-slate-600">
              La decision correcta depende del modelo comercial, la etapa de crecimiento, el tipo de cliente y el proceso que quieres mejorar.
            </p>
          </div>
          <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
            {webSolutionCards.map(([title, audience, result]) => (
              <article class="group rounded-xl border border-slate-200 bg-slate-50 p-5 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white hover:shadow-premium">
                <span class="icon-box mb-5"><Icon name="layers" class="size-5" /></span>
                <h3 class="text-xl font-black group-hover:text-enix-red">{title}</h3>
                <p class="mt-3 text-sm font-bold leading-6 text-slate-700">{audience}</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">{result}</p>
                <a class="mt-5 inline-flex items-center gap-2 text-sm font-black text-enix-red" href="#formulario-servicio">
                  Revisar este proyecto <Icon name="chevronRight" class="size-4" />
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <section id="ejemplos" class="section bg-white">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Ejemplos de aplicación</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">{isWebService ? "Ejemplos de soluciones que podemos construir." : "Cómo puede aplicarse en una empresa real."}</h2>
          {isWebService && <p class="mt-5 text-lg leading-8 text-slate-600">Usamos escenarios demostrativos, no clientes falsos, para mostrar como cambia el enfoque segun cada negocio.</p>}
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {(isWebService ? webScenarios : service.applications).map(([title, text]) => (
            <article class="group rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 transition hover:-translate-y-1 hover:border-red-200 hover:bg-white hover:shadow-xl hover:shadow-red-100/50">
              {isWebService ? (
                <div class="mb-5 overflow-hidden rounded-xl border border-slate-200 bg-white p-3">
                  <div class="rounded-lg bg-gradient-to-br from-slate-950 via-slate-800 to-red-950 p-4">
                    <div class="h-2 w-2/3 rounded-full bg-white/80"></div>
                    <div class="mt-2 h-2 w-1/2 rounded-full bg-white/30"></div>
                    <div class="mt-4 grid grid-cols-3 gap-2">
                      <span class="h-10 rounded-md bg-white/10"></span>
                      <span class="h-10 rounded-md bg-red-500/30"></span>
                      <span class="h-10 rounded-md bg-white/10"></span>
                    </div>
                  </div>
                </div>
              ) : (
                <span class="icon-box mb-5"><Icon name="layers" class="size-5" /></span>
              )}
              <h3 class="text-xl font-black">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-ink text-white">
      <div class="container grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="eyebrow">Proceso</p>
          <h2 class="mt-3 text-4xl font-black leading-tight md:text-5xl">Una ruta ordenada para avanzar con criterio.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-300">Cada servicio se adapta al contexto, pero el método evita improvisar: primero entendemos, luego construimos y finalmente medimos.</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {(isWebService ? webTimeline.map((title) => [title, "Avanzamos con una decision clara, entregables visibles y validacion antes de pasar a la siguiente etapa."] as [string, string]) : service.process).map(([title, text], index) => (
            <article class="rounded-2xl border border-white/10 bg-white/[0.055] p-5">
              <span class="text-xs font-black text-red-300">0{index + 1}</span>
              <h3 class="mt-3 text-xl font-black">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div>
          <p class="eyebrow">Tecnología real</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Trabajamos con tecnología moderna para construir soluciones rápidas, medibles y escalables.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">No mostramos logos de clientes sin autorización. Esta franja resume plataformas y herramientas que podemos integrar según el proyecto.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            {(isWebService ? webTechnologies : service.technologies).map((tech) => (
              <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-black text-slate-700">{tech}</span>
            ))}
          </div>
        </div>
        <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6">
          <p class="eyebrow">Errores comunes que evitamos</p>
          <div class="mt-6 grid gap-3">
            {service.errors.map((error) => (
              <div class="flex gap-3 rounded-2xl bg-white p-4 text-sm font-bold leading-6 text-slate-700">
                <Icon name="alert" class="mt-0.5 size-5 shrink-0 text-enix-red" />
                {error}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Servicios relacionados</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Un servicio funciona mejor cuando conversa con el resto del sistema.</h2>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-3">
          {relatedServices.map((item) => (
            <a class="group rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-red-200 hover:shadow-xl hover:shadow-red-100/50" href={`/servicios/${item.slug}/`}>
              <span class="grid size-12 place-items-center rounded-2xl bg-red-50 text-enix-red"><Icon name={item.icon} class="size-6" /></span>
              <h3 class="mt-5 text-xl font-black text-slate-950">{item.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>
              <span class="mt-5 inline-flex items-center text-sm font-black text-enix-red">Ver servicio <Icon name="chevronRight" class="ml-1 size-4" /></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">
        <div>
          <p class="eyebrow">Preguntas frecuentes</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Dudas antes de avanzar.</h2>
        </div>
        <div class="grid gap-4">
          {service.faq.map(([question, answer]) => (
            <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 open:bg-white open:shadow-lg">
              <summary class="cursor-pointer list-none text-lg font-black text-slate-950">{question}</summary>
              <p class="mt-4 leading-7 text-slate-600">{answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
