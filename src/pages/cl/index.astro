---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import LocationSelector from "@/components/LocationSelector";
import LocationSuggestion from "@/components/LocationSuggestion";
import Icon from "@/components/Icon.astro";
import { site } from "@/data/site";
import { marketList } from "@/data/markets";

export const prerender = true;

const title = "Marketing digital, web, SEO y automatizacion en Chile | ENIX STUDIO";
const description =
  "Hub de cobertura en Chile para empresas que necesitan desarrollo web, SEO, paid media, automatizacion e IA con paginas locales indexables.";
const canonical = `${site.url}/cl/`;

const breadcrumbs = [
  { name: "Inicio", url: site.url },
  { name: "Chile", url: canonical },
];

const services = [
  ["Desarrollo web", "Sitios rapidos, claros y preparados para convertir consultas reales."],
  ["SEO avanzado", "Arquitectura, contenido y paginas locales para capturar demanda organica."],
  ["Paid media", "Campanas conectadas a landing pages, tracking y oportunidades comerciales."],
  ["Automatizacion e IA", "Flujos para responder, filtrar y dar seguimiento sin perder leads."],
];

const industries = Array.from(new Set(marketList.flatMap((market) => market.industries))).slice(0, 10);

const extraSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Marketing digital, desarrollo web, SEO y automatizacion en Chile",
    provider: { "@type": "Organization", name: site.name, url: site.url },
    areaServed: { "@type": "Country", name: "Chile" },
    serviceType: ["Desarrollo web", "SEO", "Paid Media", "Automatizacion comercial", "IA aplicada a ventas"],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical} breadcrumbs={breadcrumbs} extraSchemas={extraSchemas}>
  <Header currentPath={Astro.url.pathname} client:load />
  <main>
    <section class="relative overflow-hidden bg-enix-ink py-24 text-white lg:py-28">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-enix-red/70 to-transparent"></div>
      <div class="container relative">
        <div class="max-w-4xl">
          <p class="eyebrow">Cobertura Chile</p>
          <h1 class="mt-4 text-5xl font-black leading-tight md:text-7xl">
            Marketing digital local para empresas que necesitan crecer con datos.
          </h1>
          <p class="mt-6 max-w-3xl text-lg font-semibold leading-8 text-slate-300">
            ENIX STUDIO organiza estrategia, web, SEO, campanas, automatizacion e IA para empresas en Chile, con rutas locales claras e indexables.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn btn-primary" href="/diagnostico?zona=chile">Solicitar diagnostico en Chile</a>
            <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
          </div>
        </div>

        <div class="mt-12 space-y-5">
          <LocationSuggestion client:idle />
          <LocationSelector />
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Mercados locales</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">URLs locales, contenido unico y rutas reales de conversion.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Cada mercado tiene una pagina propia para orientar busquedas locales, campanas y diagnosticos sin depender de contenido cambiado solo por JavaScript.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {marketList.map((market) => (
            <a class="group rounded-lg border border-slate-200 bg-slate-50 p-5 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white hover:shadow-premium" href={`/cl/${market.slug}/`}>
              <span class="icon-box mb-5"><Icon name="map" class="size-5" /></span>
              <h3 class="text-2xl font-black group-hover:text-enix-red">{market.city}</h3>
              <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">{market.marketContext}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Servicios principales</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Un sistema digital conectado a ventas.</h2>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {services.map(([name, text]) => (
            <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <h3 class="text-xl font-black">{name}</h3>
              <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[1fr_0.9fr]">
        <div>
          <p class="eyebrow">Industrias</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Cobertura para sectores con intencion comercial real.</h2>
          <div class="mt-6 flex flex-wrap gap-2">
            {industries.map((industry) => (
              <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-700">{industry}</span>
            ))}
          </div>
        </div>
        <div class="rounded-lg bg-enix-ink p-7 text-white">
          <p class="eyebrow">Diagnostico</p>
          <h2 class="mt-3 text-3xl font-black">Detectemos que mercado, servicio y ruta conviene priorizar.</h2>
          <p class="mt-4 text-sm font-semibold leading-6 text-slate-400">
            Revisamos presencia digital, claridad comercial, visibilidad, conversion, tracking y seguimiento para proponer acciones concretas.
          </p>
          <a class="btn btn-primary mt-7" href="/diagnostico?zona=chile">Solicitar diagnostico</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
