---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import ChileMarketMap from "@/components/ChileMarketMap";
import Icon from "@/components/Icon.astro";
import { site } from "@/data/site";

export const prerender = true;

const title = "Agencia de Marketing, Tecnologia y Automatizacion en Chile | Enix Studio";
const description =
  "Enix Studio ayuda a empresas en Chile a crecer con desarrollo web, SEO, paid media, branding, automatizacion, IA y analitica. Especialistas en empresas B2B, industriales y tecnologicas.";
const canonical = `${site.url}/cl/`;

const breadcrumbs = [
  { name: "Inicio", url: site.url },
  { name: "Chile", url: canonical },
];

const services = [
  ["Desarrollo web", "Sitios, landings y plataformas preparadas para conversion, SEO y medicion."],
  ["SEO avanzado", "Arquitectura, contenido y senales tecnicas para capturar demanda organica."],
  ["Paid media", "Campanas conectadas a landing pages, tracking y oportunidades comerciales."],
  ["Automatizacion e IA", "Flujos para responder, filtrar y dar seguimiento sin perder leads."],
  ["Branding", "Sistemas visuales y mensajes que elevan confianza en mercados exigentes."],
  ["Analitica", "Eventos, dashboards y medicion para decidir con datos."],
];

const industries = [
  "Empresas B2B",
  "Empresas industriales",
  "Proveedores mineros",
  "Servicios profesionales",
  "Ecommerce",
  "Tecnologia",
  "Educacion",
  "Comercio regional",
];

const visibleRegionalCards = [
  {
    title: "Region Metropolitana",
    text: "Marketing, desarrollo web, SEO y automatizacion para empresas B2B, servicios profesionales, ecommerce y negocios de alta competencia digital.",
    href: "/cl/region-metropolitana/",
    cta: "Ver soluciones para Region Metropolitana",
  },
  {
    title: "Region de Antofagasta",
    text: "Soluciones digitales para empresas industriales, proveedores mineros, servicios tecnicos y negocios B2B que necesitan transmitir confianza y captar oportunidades.",
    href: "/cl/region-antofagasta/",
    cta: "Ver soluciones para Region de Antofagasta",
  },
  {
    title: "Valparaiso",
    text: "Marketing digital, desarrollo web y posicionamiento para empresas regionales, comercio, turismo, educacion y servicios.",
    href: "/diagnostico?zona=valparaiso",
    cta: "Solicitar diagnostico para Valparaiso",
  },
  {
    title: "Biobio",
    text: "Servicios digitales para empresas industriales, B2B, educacion y negocios regionales con foco en presencia, captacion y medicion.",
    href: "/diagnostico?zona=biobio",
    cta: "Solicitar diagnostico para Biobio",
  },
];

const extraSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Marketing, tecnologia y automatizacion para empresas en Chile",
    provider: { "@type": "Organization", name: site.name, url: site.url },
    areaServed: { "@type": "Country", name: "Chile" },
    serviceType: ["Desarrollo web", "SEO", "Paid Media", "Branding", "Automatizacion", "Analitica"],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical} breadcrumbs={breadcrumbs} extraSchemas={extraSchemas}>
  <Header currentPath={Astro.url.pathname} client:load />
  <main>
    <section class="relative overflow-hidden bg-enix-ink py-24 text-white lg:py-28">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-enix-red/70 to-transparent"></div>
      <div class="container relative">
        <div class="max-w-5xl">
          <p class="eyebrow">Chile</p>
          <h1 class="mt-4 text-5xl font-black leading-tight md:text-7xl">
            Agencia de marketing, tecnologia y automatizacion para empresas en Chile
          </h1>
          <p class="mt-6 max-w-3xl text-lg font-semibold leading-8 text-slate-300">
            Enix Studio trabaja con empresas en Chile que necesitan mejorar su presencia digital, captar oportunidades, automatizar seguimiento y tomar decisiones con datos.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn btn-primary" href="/diagnostico?zona=chile">Solicitar diagnostico para mi empresa</a>
            <a class="btn btn-secondary" href="#mercados">Explorar mercados</a>
          </div>
        </div>
      </div>
    </section>

    <div id="mercados">
      <ChileMarketMap client:visible />
    </div>

    <section class="section bg-white">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Contenido regional visible</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Mercados prioritarios sin convertir el sitio en un directorio de ciudades.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Las regiones activas tienen URLs propias, metadata unica y contenido visible. Valparaiso y Biobio quedan como mercados en preparacion hasta tener contenido suficiente.
          </p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {visibleRegionalCards.map((card) => (
            <article class="rounded-xl border border-slate-200 bg-slate-50 p-6 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white hover:shadow-premium">
              <span class="icon-box mb-5"><Icon name="map" class="size-5" /></span>
              <h3 class="text-2xl font-black">{card.title}</h3>
              <p class="mt-3 leading-7 text-slate-600">{card.text}</p>
              <a class="mt-5 inline-flex items-center gap-2 font-black text-enix-red" href={card.href}>
                {card.cta} <Icon name="chevronRight" class="size-4" />
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Servicios por mercado</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">La misma calidad estrategica, ajustada al contexto de cada empresa.</h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {services.map(([name, text]) => (
            <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
              <h3 class="text-xl font-black">{name}</h3>
              <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[1fr_0.9fr]">
        <div>
          <p class="eyebrow">Industrias clave</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Foco en mercados donde la confianza digital impacta ventas.</h2>
          <div class="mt-6 flex flex-wrap gap-2">
            {industries.map((industry) => (
              <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-700">{industry}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl bg-enix-ink p-7 text-white">
          <p class="eyebrow">Trabajo remoto</p>
          <h2 class="mt-3 text-3xl font-black">Procesos digitales para empresas en distintas regiones.</h2>
          <p class="mt-4 text-sm font-semibold leading-6 text-slate-400">
            Trabajamos con diagnostico, reuniones online, entregables claros, seguimiento por etapas y medicion para que la ubicacion no frene el avance.
          </p>
          <a class="btn btn-primary mt-7" href="/diagnostico?zona=chile">Solicitar diagnostico nacional</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
