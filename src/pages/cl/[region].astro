---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import LocationSelector from "@/components/LocationSelector";
import Icon from "@/components/Icon.astro";
import { markets, type Market } from "@/data/markets";
import { site } from "@/data/site";

export const prerender = true;

export async function getStaticPaths() {
  return Object.entries(markets).map(([region, data]) => ({
    params: { region },
    props: { region, data },
  }));
}

const { region, data } = Astro.props as { region: string; data: Market };
const canonical = `${site.url}/cl/${region}/`;
const breadcrumbs = [
  { name: "Inicio", url: site.url },
  { name: "Chile", url: `${site.url}/cl/` },
  { name: data.city, url: canonical },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  name: `${site.name} - ${data.city}`,
  url: canonical,
  email: site.email,
  areaServed: [{ "@type": "City", name: data.city }, { "@type": "Country", name: data.country }],
  address: { "@type": "PostalAddress", addressCountry: "CL", addressLocality: data.city },
  description: data.metaDescription,
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `Marketing digital, desarrollo web y SEO en ${data.city}`,
  description: data.marketContext,
  provider: { "@type": "Organization", name: site.name, url: site.url },
  areaServed: { "@type": "City", name: data.city },
  serviceType: data.recommendedServices,
};
---

<BaseLayout
  title={data.title}
  description={data.metaDescription}
  canonical={canonical}
  breadcrumbs={breadcrumbs}
  faqItems={data.faqs}
  extraSchemas={[localBusinessSchema, serviceSchema]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <main>
    <section class="relative overflow-hidden bg-enix-ink py-24 text-white lg:py-28">
      <div class="pointer-events-none absolute -right-40 top-10 h-96 w-96 rounded-full bg-enix-red/10 blur-3xl"></div>
      <div class="container relative">
        <nav class="flex flex-wrap items-center gap-2 text-sm font-bold text-slate-400" aria-label="Breadcrumb">
          <a class="transition hover:text-white" href="/">Inicio</a>
          <span>/</span>
          <a class="transition hover:text-white" href="/cl/">Chile</a>
          <span>/</span>
          <span class="text-white">{data.city}</span>
        </nav>

        <div class="mt-8 max-w-5xl">
          <p class="eyebrow">{data.city} - {data.country}</p>
          <h1 class="mt-5 text-5xl font-black leading-tight md:text-7xl">{data.h1}</h1>
          <p class="mt-6 max-w-3xl text-lg font-semibold leading-8 text-slate-300">{data.marketContext}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn btn-primary" href={data.diagnosticUrl} rel="nofollow">{data.ctaLabel}</a>
            <a class="btn btn-secondary" href="/cl/">Ver cobertura en Chile</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow">Problemas locales</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Brechas que frenan oportunidades en {data.city}.</h2>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {data.problems.map((problem) => (
            <article class="rounded-lg border border-slate-200 bg-slate-50 p-6 transition hover:-translate-y-1 hover:border-enix-red/30 hover:bg-white hover:shadow-premium">
              <span class="icon-box mb-5"><Icon name="alert" class="size-5" /></span>
              <p class="font-black leading-6">{problem}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-pearl">
      <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Servicios recomendados</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Que priorizaria ENIX STUDIO en {data.city}.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            La estrategia se ajusta al mercado local, pero mantiene una base comun: claridad comercial, URLs indexables, medicion y seguimiento.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {data.recommendedServices.map((service) => (
            <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <span class="icon-box mb-5"><Icon name="badgeCheck" class="size-5" /></span>
              <p class="text-xl font-black">{service}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-2">
        <div>
          <p class="eyebrow">Industrias</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Sectores donde una presencia digital mas clara puede cambiar la conversacion.</h2>
          <div class="mt-6 flex flex-wrap gap-2">
            {data.industries.map((industry) => (
              <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-700">{industry}</span>
            ))}
          </div>
        </div>
        <div class="space-y-4">
          {data.scenarios.map((scenario) => (
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-5">
              <p class="font-bold leading-7 text-slate-700">{scenario}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-enix-ink text-white">
      <div class="container grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="eyebrow">FAQ local</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">Preguntas frecuentes sobre marketing digital en {data.city}.</h2>
          <a class="btn btn-primary mt-8" href={data.diagnosticUrl} rel="nofollow">{data.ctaLabel}</a>
        </div>
        <div class="space-y-3">
          {data.faqs.map(([question, answer]) => (
            <details class="rounded-lg border border-white/10 bg-white/[0.055] p-5">
              <summary class="flex cursor-pointer items-center gap-3 font-black">
                <Icon name="message" class="size-5 text-enix-glow" /> {question}
              </summary>
              <p class="mt-3 leading-7 text-slate-400">{answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container">
        <LocationSelector />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
