---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import LeadModal from "@/components/LeadModal";
import { cases } from "@/data/casesData";
import { site } from "@/data/site";

export function getStaticPaths() {
  return cases.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const canonical = `${site.url}/casos/${item.slug}/`;
---

<BaseLayout
  title={`${item.title} | Casos ENIX STUDIO`}
  description={`${item.summary} Caso conceptual de ENIX STUDIO enfocado en ${item.services.join(", ")}.`}
  canonical={canonical}
  breadcrumbs={[{ name: "Inicio", url: site.url }, { name: "Casos", url: `${site.url}/casos/` }, { name: item.title, url: canonical }]}
>
  <Header currentPath={Astro.url.pathname} client:load />
  <LeadModal client:load />
  <main>
    <section class="noise relative isolate overflow-hidden pb-20 pt-36 text-white md:pt-44">
      <div class="grid-mask absolute inset-0 opacity-70"></div>
      <div class="container relative max-w-5xl">
        <p class="eyebrow">{item.label}</p>
        <h1 class="mt-5 text-5xl font-black leading-[0.98] md:text-7xl">{item.title}</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-300">{item.summary}</p>
        <div class="mt-8 flex flex-wrap gap-2">
          {item.services.map((service) => <span class="rounded-full border border-white/10 bg-white/[0.06] px-3 py-2 text-xs font-black text-slate-200">{service}</span>)}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container grid gap-10 lg:grid-cols-[0.35fr_0.65fr]">
        <aside class="lg:sticky lg:top-28 lg:self-start">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <p class="eyebrow">Resumen</p>
            <h2 class="mt-3 text-2xl font-black">{item.category}</h2>
            <p class="mt-4 leading-7 text-slate-600">{item.objective}</p>
            <a class="btn btn-primary mt-6" href="/#diagnostico">Quiero un diagnóstico</a>
          </div>
        </aside>

        <div>
          <section>
            <p class="eyebrow">Problema inicial</p>
            <h2 class="mt-3 text-4xl font-black">Qué frenaba el crecimiento</h2>
            <p class="mt-5 text-lg leading-8 text-slate-700">{item.problem}</p>
          </section>

          <section class="mt-12">
            <p class="eyebrow">Objetivo comercial</p>
            <h2 class="mt-3 text-4xl font-black">Qué debía cambiar</h2>
            <p class="mt-5 text-lg leading-8 text-slate-700">{item.objective}</p>
          </section>

          <section class="mt-12">
            <p class="eyebrow">Diagnóstico</p>
            <div class="mt-5 grid gap-3 md:grid-cols-2">
              {item.diagnosis.map((point) => (
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 font-bold text-slate-700">{point}</div>
              ))}
            </div>
          </section>

          <section class="mt-12 rounded-[2rem] bg-enix-ink p-8 text-white">
            <p class="eyebrow">Solución aplicada</p>
            <h2 class="mt-3 text-4xl font-black">{item.solution}</h2>
            <p class="mt-5 text-lg leading-8 text-slate-300">{item.result}</p>
          </section>

          <section class="mt-12">
            <p class="eyebrow">Proceso de trabajo</p>
            <div class="mt-6 grid gap-3">
              {item.process.map((step, index) => (
                <div class="flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4">
                  <span class="grid size-10 place-items-center rounded-xl bg-red-50 text-sm font-black text-enix-red">0{index + 1}</span>
                  <span class="font-black text-slate-950">{step}</span>
                </div>
              ))}
            </div>
          </section>

          <section class="mt-12">
            <p class="eyebrow">Tecnologías usadas</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {item.technologies.map((tech) => <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-700">{tech}</span>)}
            </div>
          </section>

          <section class="mt-12 grid gap-6 lg:grid-cols-2">
            <article class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6">
              <p class="eyebrow">Antes</p>
              <ul class="mt-5 grid gap-3">
                {item.before.map((point) => <li class="rounded-2xl bg-white p-4 font-bold text-slate-600">{point}</li>)}
              </ul>
            </article>
            <article class="rounded-[2rem] bg-enix-ink p-6 text-white">
              <p class="eyebrow">Después</p>
              <ul class="mt-5 grid gap-3">
                {item.after.map((point) => <li class="rounded-2xl border border-white/10 bg-white/[0.06] p-4 font-bold text-slate-200">{point}</li>)}
              </ul>
            </article>
          </section>

          <section class="mt-12">
            <p class="eyebrow">Aprendizajes</p>
            <div class="mt-5 grid gap-3">
              {item.learnings.map((learning) => (
                <div class="flex gap-3 rounded-2xl border border-slate-200 bg-white p-5">
                  <Icon name="check" class="mt-1 size-5 shrink-0 text-enix-red" />
                  <p class="font-semibold leading-7 text-slate-700">{learning}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="mt-12 rounded-[2rem] bg-enix-pearl p-8">
            <p class="eyebrow">Servicios relacionados</p>
            <h2 class="mt-3 text-3xl font-black">Podemos aplicar una solución similar a tu empresa.</h2>
            <div class="mt-5 flex flex-wrap gap-2">
              {item.services.map((service) => <a class="rounded-full bg-white px-4 py-2 text-sm font-black text-slate-700 transition hover:text-enix-red" href="/servicios/">{service}</a>)}
            </div>
            <a class="btn btn-primary mt-7" href="/#diagnostico"><Icon name="arrowUp" class="size-5" /> Solicitar diagnóstico gratuito</a>
          </section>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
